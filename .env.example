# Get a free NVIDIA API key at https://build.nvidia.com
NVIDIA_API_KEY=

# Or use OpenRouter (free tier at https://openrouter.ai)
# OPENROUTER_API_KEY=

# Or use OpenAI (https://platform.openai.com)
# OPENAI_API_KEY=

# Optional: skip onboarding prompt
# SKIP_ONBOARD=1

# Optional: web terminal authentication
# TTYD_USER=admin
# TTYD_PASS=secret

# Optional: Telegram bot (get token from @BotFather)
# TELEGRAM_BOT_TOKEN=
# SANDBOX_NAME=my-assistant
# ALLOWED_CHAT_IDS=123456789,987654321
